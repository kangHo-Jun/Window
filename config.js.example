// Google Sheets API 설정 (예시 파일)
// 이 파일을 config.js로 복사한 후 실제 값을 입력하세요

const GOOGLE_SHEETS_CONFIG = {
    // Google Cloud Console에서 생성한 API 키를 여기에 입력하세요
    // 예: 'AIzaSyD...'
    API_KEY: 'YOUR_API_KEY_HERE',

    // Google Sheets ID (스프레드시트 URL에서 추출)
    // 예: https://docs.google.com/spreadsheets/d/[SHEET_ID]/edit
    SPREADSHEET_ID: 'YOUR_SPREADSHEET_ID_HERE',

    // 시트 이름 (탭 이름) - 변경하지 마세요
    SHEETS: {
        PRODUCTS: 'products',  // 제품 정보 시트
        PRICES: 'prices'       // 가격 정보 시트
    }
};

/**
 * 사용 방법:
 *
 * 1. 이 파일을 config.js로 복사:
 *    cp config.js.example config.js
 *
 * 2. config.js를 열어서 YOUR_API_KEY_HERE와 YOUR_SPREADSHEET_ID_HERE를
 *    실제 값으로 교체
 *
 * 3. docs/google_sheets_setup_guide.md를 참고하여 설정 완료
 */

/**
 * Google Sheets API를 사용하여 데이터 가져오기
 */
async function fetchSheetData(sheetName, range = 'A:Z') {
    const url = `https://sheets.googleapis.com/v4/spreadsheets/${GOOGLE_SHEETS_CONFIG.SPREADSHEET_ID}/values/${sheetName}!${range}?key=${GOOGLE_SHEETS_CONFIG.API_KEY}`;

    try {
        const response = await fetch(url);

        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }

        const data = await response.json();
        return data.values || [];
    } catch (error) {
        console.error(`Google Sheets API 오류 (${sheetName}):`, error);
        throw error;
    }
}

/**
 * CSV 형식의 데이터를 객체 배열로 변환
 */
function parseSheetData(rows) {
    if (!rows || rows.length === 0) {
        return [];
    }

    const headers = rows[0];
    const data = [];

    for (let i = 1; i < rows.length; i++) {
        const row = rows[i];
        const item = {};

        headers.forEach((header, index) => {
            item[header] = row[index] || '';
        });

        data.push(item);
    }

    return data;
}

/**
 * 제품 데이터 로드
 */
async function loadProducts() {
    try {
        const rows = await fetchSheetData(GOOGLE_SHEETS_CONFIG.SHEETS.PRODUCTS);
        const parsedData = parseSheetData(rows);

        return parsedData.map(item => ({
            id: item.product_id,
            name: item.product_name,
            category: item.category,
            description: item.description
        }));
    } catch (error) {
        console.error('제품 데이터 로드 실패:', error);
        return getDefaultProducts();
    }
}

/**
 * 가격 데이터 로드
 */
async function loadPrices() {
    try {
        const rows = await fetchSheetData(GOOGLE_SHEETS_CONFIG.SHEETS.PRICES);
        const parsedData = parseSheetData(rows);

        return parsedData.map(item => ({
            productId: item.product_id,
            widthMin: parseInt(item.width_min),
            widthMax: parseInt(item.width_max),
            heightMin: parseInt(item.height_min),
            heightMax: parseInt(item.height_max),
            price: parseInt(item.price)
        }));
    } catch (error) {
        console.error('가격 데이터 로드 실패:', error);
        return getDefaultPrices();
    }
}

